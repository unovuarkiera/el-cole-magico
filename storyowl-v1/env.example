# StoryOwl V1 — Variables de entorno
# Copiar como .env.v1 en la raíz de storyowl-v1/
# NUNCA subir este archivo a Git

# ── APIs de IA ─────────────────────────────────────────
ANTHROPIC_KEY=sk-ant-...
OPENAI_KEY=sk-...

# ── Almacenamiento ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Base de datos ──────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ── Cola de trabajos ───────────────────────────────────
UPSTASH_REDIS_URL=redis://default:xxx@xxx.upstash.io:6379

# ── Cobro ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PDF=price_xxx
STRIPE_PRICE_LIBRO=price_xxx

# ── Email ──────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=hola@storyowl.com

# ── Gelato ─────────────────────────────────────────────
GELATO_API_KEY=xxx
GELATO_PRODUCT_UID=photobook_hardcover_20x20

# ── App ────────────────────────────────────────────────
BASE_URL=https://storyowl-v1.onrender.com
PORT=3001
NODE_ENV=production
